{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "安卓工具集",
  "version": "1.5.0",
  "identifier": "com.androidtools.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "安卓工具集 v1.5.0",
        "width": 1100,
        "minWidth": 900,
        "minHeight": 700
      }
    ]
  },
  "bundle": {
    "active": false
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
